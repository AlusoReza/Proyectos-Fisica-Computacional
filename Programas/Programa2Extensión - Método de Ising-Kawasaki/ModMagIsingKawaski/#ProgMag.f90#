
!     ESTE PROGRAMA MODELA CÓMO SE MAGNETIZA UN MATERIAL SIGUIENDO UN MODELO DE ISING Y EL MÉTODO DE MONTECARLO.

      PROGRAM MODMAGISING

      USE RANDOMNUMBER

      IMPLICIT NONE

      INTEGER*8:: I, J, K, M, X
      INTEGER*8:: NT, NN, PM, TP, MEC, PREG1, PREG2, PREG3, PART, NNP
      REAL*8:: PORCT
      REAL*8, DIMENSION(:), ALLOCATABLE:: T, EPT, EPT2, MPT, MPT2, CN, XN
      REAL*8, DIMENSION(:,:), ALLOCATABLE:: ENER, ENER2, MAG, MAG2, MPTCNP
      REAL*8, DIMENSION(:,:,:), ALLOCATABLE:: INCE, E, MAGCNP, MAGYCNPA, MAGYCNP
      INTEGER*8, DIMENSION(:,:,:,:), ALLOCATABLE:: S

!     LLAMAMOS PROGRAMA QUE GENERA NÚMEROS ALEATORIOS.
      CALL DRAN_INI(13567)
!     -------------------------------------------------
      WRITE(6,*) "-----------------------------------------------------"
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) "SE MODELARA LA MAGNETIZACION DE UN MATERIAL TAL QUE"
      WRITE(6,*) "A TEMPERATURAS BAJAS ES FERROMAGNETICO Y A ALTAS "
      WRITE(6,*) "TEMPERATURAS ES PARAMANETICO SIGUIENDO UN MODELO "
      WRITE(6,*) "DE ISING - KAWASKI CON EL METODO DE MONTECARLO. SE INTRODUCIRAN"
      WRITE(6,*) "UN DETERMINADO NUMERO DE PARTICULAS N, Y SE VERÁ SU"
      WRITE(6,*) "EVOLUCION PARA OTRO NUMERO DE TEMPERATURAS DADAS."     
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) "-----------------------------------------------------"

      CALL DATOS
!     -------------------------------------------------
      
!     -------------------------------------------------
      CALL RESULTADOS
!     -------------------------------------------------      
      
      WRITE(6,*) "-----------------------------------------------------"
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) "YA SE HAN CALCULADO LAS CORRESPONDIENTES MATRICES"
      WRITE(6,*) "S(I,J). SE HALLAN EN SUS CORRESPONDIENTES DOCUMENTOS"
      WRITE(6,*) "QUE COMIENZAN CON EL NOMBRE MSPT-TP. EL NÚMERO DE"
      WRITE(6,*) "PARTICULAS ES EL INTRODUCIDO MANUALMENTE."
      WRITE(6,*) " "
      WRITE(6,*) " "
      WRITE(6,*) "-----------------------------------------------------"
      
!     -------------------------------------------------      
      STOP
!     -------------------------------------------------
      CONTAINS
!     -------------------------------------------------
      SUBROUTINE DATOS
      
!       WRITE(6,*) " "
!       WRITE(6,*) "INTRODUZCA EL NUMERO DE TEMPERATURAS PARA LOS QUE"
!       WRITE(6,*) "QUIERES REALIZAR EL MODELO:"
!      READ(5,*) NT
!      ALLOCATE(T(1:NT))

!      WRITE(6,*) " "
!      WRITE(6,*) "AHORA INTRODUCE LAS T POR PANTALLA, EN GRADOS KELVIN:"
!      DO I = 1, NT
!         READ(5,*) T(I)
!     END DO

!      WRITE(6,*) " "
!      WRITE(6,*) "ESCRIBA EL NUMEROS DE PARTICULAS (N) PARA EL  "
!      WRITE(6,*) "QUE DESEA REALIZAR EL MODELO DE ISING:"
!      READ(6,*) NN
!      ALLOCATE(N(1:NN))      

!      WRITE(6,*) "PARA CUANTOS PASOS DESEA REALIZAR"
!      WRITE(6,*) " EL MÉTODO DE MONTECARLO:"
!     READ(5,*) PM

!     ALLOCATE(S(1:PM+1,0:NN+1,0:NN+1,1:NT))
!     ALLOCATE(E(1:PM,1:NN**2,1:NT))
!     ALLOCATE(EPROM(1:PM,1:NT))
!     ALLOCATE(MPROM(1:PM,1:NT))
!     ALLOCATE(EPT(1:NT))
!     ALLOCATE(MPT(1:NT))
!     ALLOCATE(INCE(1:PM,1:NN**2,1:NT))      
      
      NT = 10
      ALLOCATE(T(1:NT))
      T(1) = 0.15D0
      T(2) = 0.50D0
      T(3) = 0.65D0
      T(4) = 0.75D0
      T(5) = 0.80D0
      T(6) = 0.85D0
      T(7) = 1.5D0
      T(8) = 2.D0
      T(9) = 2.5D0
      T(10) = 5.D0
      
      !PM = 2000
      PM = 5000
      
      NN = 64

      MEC = PM/5
      ALLOCATE(S(0:PM+1,0:NN+1,0:NN+1,1:NT))
      ALLOCATE(ENER(0:MEC,1:NT))
      ALLOCATE(MAG(0:MEC,1:NT))
      ALLOCATE(ENER2(0:MEC,1:NT))
      ALLOCATE(MAG2(0:MEC,1:NT))
      ALLOCATE(MAGCNP(1:2,0:MEC,1:NT))
      ALLOCATE(MAGYCNP(1:NN,0:MEC,1:NT))
      ALLOCATE(MAGYCNPA(1:NN,0:MEC,1:NT))
      ALLOCATE(EPT(1:NT))
      ALLOCATE(EPT2(1:NT))
      ALLOCATE(MPT(1:NT))
      ALLOCATE(MPT2(1:NT))
      ALLOCATE(CN(1:NT))
      ALLOCATE(XN(1:NT))
      ALLOCATE(MPTCNP(1:NN,1:NT))
      ALLOCATE(INCE(0:PM,1:NN**2,1:NT))

      CALL PREGUNTAS

      
      
      END SUBROUTINE DATOS
!     -------------------------------------------------
      SUBROUTINE PREGUNTAS
            WRITE(6,*) " "
      WRITE(6,*) "EN EL MODELO DE ISING SE CONSIDERA QUE PARA"
      WRITE(6,*) "EL CONSIDERADO MATERIAL EXISTE UNA RED "
      WRITE(6,*) "BIDIMENSIONAL DE N*N PARTÍCULAS CADA UNA CON"
      WRITE(6,*) "UNA VARIABLE, SPÍN, QUE TOMA LOS VALORES"
      WRITE(6,*) "1 O -1, TAL QUE FORMA UNA MATRIZ S(I,J)."

      WRITE(6,*) " "
      WRITE(6,*) "SI DESEA TENER LA MISMA DISTRIBUCION MATRICIAL"
      WRITE(6,*) "DE S PARA TODAS LAS TEMPERATURAS, PULSE 1, EN"
      WRITE(6,*) "CASO CONTRARIO, PULSE 2."
3     READ(5,*) PREG1
      
      PREG1 = 1
!     -------------------------------------------------            
      IF (PREG1.EQ.1) THEN
         
      WRITE(6,*) " "
      WRITE(6,*) "SI DESEA QUE SEA RELLENADA PARA UN MISMO VALOR"
      WRITE(6,*) "PULSE 1. EN CASO CONTRARIO, QUE SEA RELLENADA"
      WRITE(6,*) "DE MANERA ALEATORIA, PULSE 2."
      WRITE(6,*) "(ES DECIR, ORDENADA O DESORDENADA RESPECTIVAMENTE.)"
      WRITE(6,*) 'SI DESEA QUE TENGA UNA MAGNITIZACIÓN INICIAL ESPECIFICA,'
      WRITE(6,*) 'PULSE 3.'
 1    READ(5,*) PREG2

      PREG2 = 3
      
      IF (PREG2.EQ.1) THEN

         CALL SORD1        
      
      ELSE IF (PREG2.EQ.2) THEN
         
         CALL SDESORD1

      ELSE IF (PREG2.EQ.3) THEN

         CALL MAGINI1
         
      ELSE
         
         WRITE(6,*) "POR FAVOR, PULSE 1, 2 O 3."
         GO TO 1
                  
      END IF
!     -------------------------------------------------         
      ELSE IF(PREG1.EQ.2) THEN
         DO K = 1, NT
      WRITE(6,*) " "
      WRITE(6,*) "- PARA LA MATRIZ DE T(,",K,")."
      WRITE(6,*) "SI DESEA QUE SEA RELLENADA PARA UN MISMO VALOR"
      WRITE(6,*) "PULSE 1, EN CASO CONTRARIO, QUE SEA RELLENADA"
      WRITE(6,*) "DE MANERA ALEATORIA, PULSE 2."
      WRITE(6,*) "(ES DECIR, ORDENADA O DESORDENADA RESPECTIVAMENTE.)"
 2    READ(6,*) PREG2

      IF (PREG2.EQ.1) THEN
         
         CALL SORD2
         
      ELSE IF (PREG2.EQ.2) THEN
         
         CALL SDESORD2
         
      ELSE IF (PREG2.EQ.3) THEN

         CALL MAGINI2
         
      ELSE         
         WRITE(6,*) "POR FAVOR, PULSE 1, 2 O 3."
         GO TO 2         
      END IF
      
      END DO                     
!     -------------------------------------------------              
      ELSE
         WRITE(6,*) "POR FAVOR, PULSE 1 O 2."
         GO TO 3
      END IF   

!     -------------------------------------------------
      WRITE(6,*) 'DESEA QUE EL SISTEMA TENGA CONDICIONES'
      WRITE(6,*) 'DE CONTORNO PERIODICAS, PULSE 1, O FIJAS EN'
      WRITE(6,*) 'EL EJE Y, PULSE 2.'
4     READ(5,*) PREG3

      PREG3 = 2

      IF (PREG3.EQ.1) THEN
         CALL METMONTCARLOS
         CALL ENMEDIA
         CALL MAGN
         CALL MAGNPD
         CALL CNYTC
         CALL XNYTC
      ELSE IF (PREG3.EQ.2) THEN
         CALL METMONTCARLOS
         CALL ENMEDIA
         CALL MAGN
         CALL MAGNPD
         CALL CNYTC
         CALL XNYTC
      ELSE
         WRITE(6,*) 'POR FAVOR, PULSE 1 O 2.'
         GO TO 4
      END IF   
      	
      END SUBROUTINE PREGUNTAS
!     -------------------------------------------------
      SUBROUTINE SORD1
      
      WRITE(6,*) " "
      WRITE(6,*) "DESEA QUE SE RELLENE DE 1 O -1. INTRODUZCALO."
 4    READ(5,*) X

      IF(X.EQ.1) THEN
         
      DO K = 1, NT
         DO I = 1, NN
            DO J = 1, NN
               S(0,I,J,K) = 1
            END DO
         END DO
      END DO 

      ELSE IF (X.EQ.-1) THEN
         
      DO K = 1, NT   
         DO I = 1, NN
            DO J = 1, NN
               S(0,I,J,K) = -1
            END DO
         END DO
      END DO   

      ELSE
         WRITE(6,*) "POR FAVOR, INTRODUZCA 1 O -1"
         GO TO 4
      END IF
         

      END SUBROUTINE SORD1
!     -------------------------------------------------
      SUBROUTINE SDESORD1
      INTEGER*8:: NUMAL

      DO K = 1, NT
         DO I = 1, NN
            DO J = 1, NN
            
      NUMAL = I_DRAN(INT8(2.D0))
      IF(NUMAL.EQ.2) THEN
      
         S(0,I,J,K) = 1

      ELSE 
         
         S(0,I,J,K) = -1  

      END IF

            END DO
         END DO
      END DO 

      END SUBROUTINE SDESORD1
!     -------------------------------------------------
      SUBROUTINE SORD2

      WRITE(6,*) " "
      WRITE(6,*) "DESEA QUE SE RELLENE DE 1 O -1. INTRODUZCALO."
 5    READ(5,*) X

      IF(X.EQ.1) THEN
         
      DO I = 1, NN
         DO J = 1, NN
            S(0,I,J,K) = 1
         END DO

      END DO

      ELSE IF (X.EQ.-1) THEN
           
      DO I = 1, NN
         DO J = 1, NN
            S(0,I,J,K) = -1
         END DO
      END DO   

      ELSE
         WRITE(6,*) "POR FAVOR, INTRODUZCA 1 O -1"
         GO TO 5
      END IF

      END SUBROUTINE SORD2
!     -------------------------------------------------
      SUBROUTINE SDESORD2

      DO I = 1, NN
        DO J = 1, NN
         
      IF(I_DRAN(INT8(2.D0)).GT.1) THEN
      
         S(0,I,J,K) = 1

      ELSE 
         
         S(0,I,J,K) = -1  

      END IF

         END DO
      END DO

      END SUBROUTINE SDESORD2   
!     -------------------------------------------------
      SUBROUTINE MAGINI1
        
      WRITE(6,*) 'LA MAGNETIZACION SERA FRACCION DE UNA DIVISION DE S'
      WRITE(6,*) 'POR DOMINIOS, INTRODUZCA LA PARTICION QUE DESEA'
      WRITE(6,*) 'INTRODUCIR. DE 0 A 10. SIENDO 0 Y 10 COMPLETAMENTE'
      WRITE(6,*) 'MAGNETIZADO CON TODO 1 O -1 RESPECTIVAMENTE, Y 5'
      WRITE(6,*) 'UNA MAGNETIZACIÓN NULA SIENDO LA PARTE INFERIOR'
      WRITE(6,*) '-1 Y LA PARTE SUPERIOR +1. LA DIVISIÓN SERÁ PERFECTA.'
      READ(5,*) PART

      PART = 9

      PORCT = DBLE(PART)/10.D0
      NNP = NN*PORCT
      
      DO K = 1, NT
         DO I = 1, NN
            DO J = NNP+1, NN
               S(0,I,J,K) = 1
            END DO
         END DO
      END DO 
         
      DO K = 1, NT   
         DO I = 1, NN
            DO J = 1, NNP
               S(0,I,J,K) = -1
            END DO
         END DO
      END DO
      
      END SUBROUTINE MAGINI1 
!     -------------------------------------------------
      SUBROUTINE MAGINI2
        
      WRITE(6,*) 'LA MAGNETIZACION SERA FRACCION DE UNA DIVISION DE S'
      WRITE(6,*) 'POR DOMINIOS, INTRODUZCA LA PARTICION QUE DESEA'
      WRITE(6,*) 'INTRODUCIR. DE 0 A 10. SIENDO 0 Y 10 COMPLETAMENTE'
      WRITE(6,*) 'MAGNETIZADO CON TODO 1 O -1 RESPECTIVAMENTE, Y 5'
      WRITE(6,*) 'UNA MAGNETIZACIÓN NULA SIENDO LA PARTE INFERIOR'
      WRITE(6,*) '-1 Y LA PARTE SUPERIOR +1. LA DIVISIÓN SERÁ PERFECTA.'

      DO K = 1, NT
         
         WRITE(6,*) 'QUE PARTICION DESEA PARA LA TEMPERATURA:', T(K)
         READ(5,*) PART
         
         PORCT = DBLE(PART)/10.D0
         NNP = NN*PORCT
         
         DO I = NNP+1, NN
            DO J = NNP+1, NN
               S(0,I,J,K) = 1
            END DO
         END DO
          
         DO I = 1, NNP
            DO J = 1, NNP
               S(0,I,J,K) = -1
            END DO
         END DO
         
      END DO   
      
      END SUBROUTINE MAGINI2
!     -------------------------------------------------    
!     TAL CUAL LAS CONDICIONES PARA EL MODELO QUE ESTAMOS TRABAJANDO, NO TIENE MUCHA HISTORIA. SI CONSIDERAMOS UNA MATRIZ DE NN PARTICULAS, CONSIDERAMOS LA POSICIÓN INICIAL DE LA PRIMERA COMO 1 Y DE LA ÚLTIMA CÓMO NN. LA POSICIÓN 0 Y NN+1 DEFINEN LAS CONDICIONES DE CONTORNO.
      SUBROUTINE CONDCONTPER
      
      DO I=1,NN
         DO J = 1, NN
            S(M+1,I,J,TP) = S(M,I,J,TP)
         END DO
      END DO
         
      DO I = 1, NN
         S(M,I,0,TP) = S(M,I,NN,TP)
         S(M,I,NN+1,TP) = S(M,I,1,TP)
      END DO

      DO J = 1, NN
         S(M,0,J,TP) = S(M,NN,J,TP)
         S(M,NN+1,J,TP) = S(M,1,J,TP)
      END DO   

      END SUBROUTINE CONDCONTPER
!     -------------------------------------------------
      SUBROUTINE CONDCONTYFIJ
      
      DO I=1,NN
         DO J = 1, NN
            S(M+1,I,J,TP) = S(M,I,J,TP)
         END DO
      END DO
      
      DO I = 1, NN
         S(M,I,0,TP) = -1
         S(M,I,NN+1,TP) = 1
      END DO
      
      DO J = 1, NN
         S(M,0,J,TP) = S(M,NN,J,TP)
         S(M,NN+1,J,TP) = S(M,1,J,TP)
      END DO   

      END SUBROUTINE CONDCONTYFIJ
!     -------------------------------------------------
      
      SUBROUTINE METMONTCARLOS

      INTEGER*8:: A, B, C, D, AUX
      REAL*8:: AE1, AE2, P, ZM, NA
      
      DO TP=1, NT
         
      DO M=0, PM-1
            
      IF (PREG3.EQ.1) THEN   
         CALL CONDCONTPER
      ELSE
         CALL CONDCONTYFIJ
      END IF
      
      DO K = 1, NN**2
            
         A = I_DRAN(NN)
         B = I_DRAN(NN)
         
         C = I_DRAN(NN)
         D = I_DRAN(NN)
         
         IF (S(M,A,B,TP).NE.S(M,C,D,TP)) THEN
          
         AE1=S(M,A+1,B,TP)+S(M,A-1,B,TP)+S(M,A,B+1,TP)+S(M,A,B-1,TP)
         AE2=S(M,C+1,D,TP)+S(M,C-1,D,TP)+S(M,C,D+1,TP)+S(M,C,D-1,TP)
         
         !IF (((((A+1).EQ.C).OR.((A-1).EQ.C)).AND.(B.EQ.D)).OR.((A.EQ.C).AND.(((B+1).EQ.D).OR.((B-1).EQ.D)))) THEN
         !   AE1 = AE1 - S(M,C,D,TP)	
         !   AE2 = AE2 - S(M,A,B,TP)	
         !END IF

         INCE(M,K,TP)= 0.5D0*(S(M,A,B,TP)-S(M,C,D,TP))*(AE1-AE2) !S(M,A,B,TP)*AE1 + S(M,C,D,TP)*AE2

         ZM = EXP(-INCE(M,K,TP)/T(TP))   
         P = DMIN1(1.D0, ZM)
      
         NA = DRAN_U()

         IF (NA.LT.P) THEN
            AUX = S(M+1,A,B,TP)
            S(M+1,A,B,TP) = S(M+1,C,D,TP)
            S(M+1,C,D,TP) = AUX             
         END IF
         
         END IF
         
      END DO
      
      END DO
   
      END DO
      
      END SUBROUTINE METMONTCARLOS
!     -------------------------------------------------
      SUBROUTINE ENMEDIA

      DO TP =1, NT
         EPT(TP) = 0.D0
         EPT2(TP) = 0.D0
      DO M = 0, PM, 5
            
         ENER(M/5,TP) = 0.D0
          
         DO I = 1, NN
         DO J = 1, NN
            ENER(M/5,TP) = ENER(M/5,TP) - (0.5D0)*S(M,I,J,TP)*(S(M,I+1,J,TP)+S(M,I-1,J,TP)+S(M,I,J+1,TP)+S(M,I,J-1,TP))
         END DO      
         END DO
      
         ENER(M/5,TP) = ENER(M/5,TP)/NN**2.D0
         ENER2(M/5,TP) = (ENER(M/5,TP)**2.D0)/NN**2.D0
      
         EPT(TP) = EPT(TP) + ENER(M/5,TP)
         EPT2(TP) = EPT2(TP) + ENER2(M/5,TP)
         
      END DO

         EPT(TP) = EPT(TP)/MEC
         EPT2(TP) = EPT2(TP)/MEC
      
      END DO

      
      END SUBROUTINE ENMEDIA
      
!     -------------------------------------------------
      SUBROUTINE MAGN
      
      DO TP =1, NT
         
         MPT(TP) = 0.D0
         MPT2(TP) = 0.D0
         
      DO M=0, PM, 5
            
         MAG(M/5, TP) = 0.D0
         
         DO I=1, NN
         DO J=1, NN
               
            MAG(M/5,TP) = MAG(M/5,TP)+S(M,I,J,TP)
            
         END DO   
         END DO

         MAG(M/5,TP) = ABS(MAG(M/5,TP))/(DBLE(NN)**2)
         MAG2(M/5,TP) = (ABS(MAG(M/5,TP))**2.D0)/(DBLE(NN)**2)

         MPT(TP) = MPT(TP) + MAG(M/5,TP)
         MPT2(TP) = MPT2(TP) + MAG2(M/5,TP)
         
      END DO

      MPT(TP) = MPT(TP)/MEC
      MPT2(TP) = MPT2(TP)/MEC
      
      END DO
      
      END SUBROUTINE MAGN
!     -------------------------------------------------
      SUBROUTINE MAGNPD
      
      DO TP =1, NT
           
         DO I = 1, NN
            MPTCNP(I,TP) = 0.D0
         END DO
      
      DO M=0, PM, 5

         DO I = 1, 2
            MAGCNP(I,M/5,TP) = 0.D0
         END DO

         DO I = 1, NN
            MAGYCNP(I, M/5,TP) = 0.D0
         END DO   
      
         DO I=1, NN
         DO J =1, NNP
               
            MAGCNP(1,M/5,TP) = MAGCNP(1,M/5,TP)+S(M,I,J,TP)
            
         END DO   
         END DO

         DO I=1, NN
         DO J =NNP+1, NN
               
            MAGCNP(2,M/5,TP) = MAGCNP(2,M/5,TP)+S(M,I,J,TP)
            
         END DO   
         END DO

         MAGCNP(1,M/5,TP) = MAGCNP(1,M/5,TP)/(DBLE(NN)**2)
         MAGCNP(2,M/5,TP) = MAGCNP(2,M/5,TP)/(DBLE(NN)**2)

         DO J = 1, NN
         DO I = 1, NN
            MAGYCNP(J,M/5,TP) = (MAGYCNP(J,M/5,TP)+S(M,I,J,TP))/(DBLE(NN))
         END DO
         END DO
         
         DO J = 1, NN   
            MPTCNP(J,TP) = MPTCNP(J,TP) + MAGYCNP(J,M/5,TP)
         END DO
      
      END DO
      
         DO I = 1, NN
            MPTCNP(I,TP) = MPTCNP(I,TP)/NN
         END DO
         
      END DO
      
      END SUBROUTINE MAGNPD
!     -------------------------------------------------
      SUBROUTINE CNYTC

      DO TP = 1, TP
         CN(TP) = (1.D0/((NN*T(TP))**2.D0))*(EPT2(TP)-EPT(TP)**2.D0)
      END DO
      
      END SUBROUTINE CNYTC  
!     -------------------------------------------------      
      SUBROUTINE XNYTC

      DO TP = 1, TP
         XN(TP) = (1/((NN**2)*T(TP)))*(MPT2(TP)-MPT(TP)**2.D0)   
      END DO

      END SUBROUTINE XNYTC  
!     ------------------------------------------------- 
      SUBROUTINE RESULTADOS
      CHARACTER*8:: NUM
      CHARACTER*50, DIMENSION(:), ALLOCATABLE:: MSPT, MEPMT, MPEYT, MAGPDT
      
      
      ALLOCATE(MSPT(1:NT))
      ALLOCATE(MEPMT(1:NT))
      ALLOCATE(MPEYT(1:NT))
      ALLOCATE(MAGPDT(1:NT))
      
      DO TP = 1, NT
      	WRITE(NUM,999) TP
999 	FORMAT(I1)
      	MSPT(TP) = 'MSPT'//NUM//'.dat'
        MEPMT(TP) = 'MEPMT'//NUM//'.dat'
        MPEYT(TP) = 'MPEYT'//NUM//'.dat'
        MAGPDT(TP) = 'MAGPDT'//NUM//'.dat'
      END DO
	
      DO TP = 1, NT
      OPEN(20+TP, FILE = MSPT(TP), STATUS = 'UNKNOWN')
      	 WRITE(20+TP,*) '#MATRICES S(I,J).'
         DO M = 0, PM
         DO J = 1, NN
         WRITE(20+TP,*) (S(M,I,J,TP), I =1, NN)
         END DO
         WRITE(20+TP,*)
         WRITE(20+TP,*)
         END DO
      CLOSE(20+TP)
      END DO
   
      DO TP = 1, NT
      OPEN(150+TP, FILE = MPEYT(TP), STATUS = 'UNKNOWN')
      	 WRITE(150+TP,*) '#EJE Y, MAG. EJE Y'
      	 DO J=1, NN
            WRITE(150+TP,*) J, MPTCNP(J,TP)
         END DO
      CLOSE(150+TP)
      END DO
   
      DO TP = 1, NT
      OPEN(250+TP, FILE = MAGPDT(TP), STATUS = 'UNKNOWN')
      	 WRITE(250+TP,*) '#TEMP., MAG. PROM. DOM. 1,  MAG. PROM. DOM. 2.'
      	 DO M=0, MEC
            WRITE(250+TP,*) M*5, MAGCNP(1,M,TP), MAGCNP(2,M,TP), MAGCNP(1,M,TP)+MAGCNP(2,M,TP) 
         END DO
      CLOSE(250+TP)
      END DO
   
      DO TP = 1, NT
      OPEN(450+TP, FILE = MEPMT(TP), STATUS = 'UNKNOWN')
      	 WRITE(450+TP,*) '#UNIDAD DE TIEMPO, MAGNETIZACION, ENERGIA.'
      	 DO M=0, MEC
            WRITE(450+TP,*) M*5, MAG(M,TP), ENER(M,TP)
         END DO
      CLOSE(450+TP)
      END DO
      
      OPEN(900, FILE = "MEPPT.dat", STATUS = 'UNKNOWN')
      WRITE(900,*) '#TEMPERATURA, MAGN. PROMEDIO, ENER. PROMEDIO., CN Y XN'
      DO TP = 1, NT
         WRITE(900,*) T(TP), MPT(TP), EPT(TP), CN(TP), XN(TP)
      END DO
      CLOSE(900)      

      END SUBROUTINE RESULTADOS
!     -------------------------------------------------
      
      END PROGRAM MODMAGISING
